# Managed by Ansible — edits will be overwritten on next deploy.
# Single EnvironmentFile shared by all four scada-* systemd units. Under
# systemd the services run side-by-side on the host (no container DNS), so the
# inter-service URLs point at 127.0.0.1 instead of compose service names.

# ─── Range identity ─────────────────────────────────────────────────────
SCADA_STACK_NAME=scada
SCADA_DOMAIN={{ scada_domain }}
SCADA_SITE_NAME={{ scada_site_name }}

# ─── HMI credentials (documented in /manual — intentional for the range) ─
SCADA_HMI_USERNAME={{ hmi_username }}
SCADA_HMI_PASSWORD={{ hmi_password }}
SCADA_HMI_VIEWER_USERNAME={{ viewer_username }}
SCADA_HMI_VIEWER_PASSWORD={{ viewer_password }}

# ─── Inter-service API keys ─────────────────────────────────────────────
# Exposed under both the SCADA_* names (read by simulator) and the bare
# names (read by bridge + hmi) so every service finds the value it expects.
SCADA_BRIDGE_API_KEY={{ bridge_api_key }}
SCADA_SIMULATOR_API_KEY={{ simulator_api_key }}
BRIDGE_API_KEY={{ bridge_api_key }}
SIMULATOR_API_KEY={{ simulator_api_key }}

# ─── Bridge wiring (was docker-compose service DNS) ─────────────────────
SIMULATOR_URL=http://127.0.0.1:9101
MODBUS_HOST=127.0.0.1
MODBUS_PORT={{ modbus_port }}
POLL_SECONDS={{ poll_seconds }}
HISTORY_LIMIT={{ history_limit }}
EVENT_LIMIT={{ event_limit }}
BRIDGE_DB_PATH=/var/lib/scada/telemetry.db

# ─── HMI wiring ─────────────────────────────────────────────────────────
BRIDGE_URL=http://127.0.0.1:9102

# ─── Exposure (informational; binding is set in each unit's ExecStart) ──
SCADA_HMI_BIND_ADDRESS={{ hmi_bind }}
SCADA_HMI_PUBLISHED_PORT={{ hmi_port }}
SCADA_MODBUS_BIND_ADDRESS={{ modbus_bind }}
SCADA_MODBUS_PUBLISHED_PORT={{ modbus_port }}
