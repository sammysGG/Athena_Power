SCADA_STACK_NAME=scada
SCADA_DOMAIN=scada.athenadev.local
SCADA_SITE_NAME=Athena Dev

# ─── HMI credentials ────────────────────────────────────────────────────
# Defaults match the public operator manual at /manual. Rotate before any
# real deployment. The cyber range expects these defaults to stand.
SCADA_HMI_USERNAME=admin
SCADA_HMI_PASSWORD=Cool2Pass

# Hard-coded read-only viewer account. Compiled into the HMI; override here
# only if the range scenario requires different defaults.
SCADA_HMI_VIEWER_USERNAME=viewer
SCADA_HMI_VIEWER_PASSWORD=viewer

# Inter-service API keys. Run ./scripts/generate-secrets.sh to populate.
SCADA_BRIDGE_API_KEY=CHANGE_ME
SCADA_SIMULATOR_API_KEY=CHANGE_ME

# Cloudflare Tunnel token (optional — only used with --profile cloudflare).
CLOUDFLARE_TUNNEL_TOKEN=CHANGE_ME

SCADA_POLL_SECONDS=1.0
SCADA_HISTORY_LIMIT=900
SCADA_EVENT_LIMIT=2000

# ─── HMI publication (operator VLAN) ────────────────────────────────────
SCADA_HMI_BIND_ADDRESS=0.0.0.0
SCADA_HMI_PUBLISHED_PORT=18080

# ─── Modbus TCP slave (OT VLAN attack surface) ──────────────────────────
# The plant PLC is reachable on this port to anyone on the OT VLAN. The
# protocol has no authentication; HR20 is the writable speed setpoint.
SCADA_MODBUS_PORT=15020
SCADA_MODBUS_BIND_ADDRESS=0.0.0.0
SCADA_MODBUS_PUBLISHED_PORT=15020
